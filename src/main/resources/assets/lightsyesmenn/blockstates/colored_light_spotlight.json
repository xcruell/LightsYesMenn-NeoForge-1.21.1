{
  "multipart": [
    {
      "when": { "facing": "up" },
      "apply": { "model": "lightsyesmenn:block/colored_light_spotlight_base" }
    },
    {
      "when": { "facing": "down" },
      "apply": { "model": "lightsyesmenn:block/colored_light_spotlight_base", "x": 180 }
    },
    {
      "when": { "facing": "north" },
      "apply": { "model": "lightsyesmenn:block/colored_light_spotlight_base", "x": 90 }
    },
    {
      "when": { "facing": "south" },
      "apply": { "model": "lightsyesmenn:block/colored_light_spotlight_base", "x": 90, "y": 180 }
    },
    {
      "when": { "facing": "west" },
      "apply": { "model": "lightsyesmenn:block/colored_light_spotlight_base", "x": 90, "y": 270 }
    },
    {
      "when": { "facing": "east" },
      "apply": { "model": "lightsyesmenn:block/colored_light_spotlight_base", "x": 90, "y": 90 }
    }
  ]
}
